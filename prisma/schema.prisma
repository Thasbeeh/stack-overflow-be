generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String            @id @default(uuid())
  username                String            @unique
  email                   String            @unique
  role                    UserRole          @default(USER)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  passwordHash            String
  answers                 Answer[]
  deletedAnswers          Answer[]          @relation("AnswerDeletedBy")
  answerComments          AnswerComment[]
  deletedAnswerComments   AnswerComment[]   @relation("AnswerCommentDeletedBy")
  answerVotes             AnswerVote[]
  questions               Question[]
  deletedQuestions        Question[]        @relation("QuestionDeletedBy")
  questionComments        QuestionComment[]
  deletedQuestionComments QuestionComment[] @relation("QuestionCommentDeletedBy")
  questionVotes           QuestionVote[]
}

model Question {
  id               String                   @id @default(uuid())
  title            String
  content          String
  authorId         String
  voteCount        Int                      @default(0)
  acceptedAnswerId String?                  @unique
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  deletedAt        DateTime?
  deletedById      String?
  search_vector    Unsupported("tsvector")? @default(dbgenerated())
  answers          Answer[]
  acceptedAnswer   Answer?                  @relation("AcceptedAnswer", fields: [acceptedAnswerId], references: [id])
  author           User                     @relation(fields: [authorId], references: [id])
  deletedBy        User?                    @relation("QuestionDeletedBy", fields: [deletedById], references: [id])
  questionComments QuestionComment[]
  questionVotes    QuestionVote[]
  tags             Tag[]                    @relation("QuestionToTag")
  @@index([search_vector], type: Gin)
}

model Answer {
  id             String          @id @default(uuid())
  content        String
  questionId     String
  authorId       String
  voteCount      Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  deletedAt      DateTime?
  deletedById    String?
  author         User            @relation(fields: [authorId], references: [id])
  deletedBy      User?           @relation("AnswerDeletedBy", fields: [deletedById], references: [id])
  question       Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answerComments AnswerComment[]
  answerVotes    AnswerVote[]
  acceptedIn     Question?       @relation("AcceptedAnswer")
}

model Tag {
  id        String     @id @default(uuid())
  name      String     @unique
  questions Question[] @relation("QuestionToTag")
}

model QuestionVote {
  userId     String
  questionId String
  value      Int      @db.SmallInt
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@id([userId, questionId])
}

model AnswerVote {
  userId   String
  answerId String
  value    Int    @db.SmallInt
  answer   Answer @relation(fields: [answerId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id])

  @@id([userId, answerId])
}

model QuestionComment {
  id          String    @id @default(uuid())
  questionId  String
  authorId    String
  content     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  deletedById String?
  author      User      @relation(fields: [authorId], references: [id])
  deletedBy   User?     @relation("QuestionCommentDeletedBy", fields: [deletedById], references: [id])
  question    Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model AnswerComment {
  id          String    @id @default(uuid())
  answerId    String
  authorId    String
  content     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  deletedById String?
  answer      Answer    @relation(fields: [answerId], references: [id], onDelete: Cascade)
  author      User      @relation(fields: [authorId], references: [id])
  deletedBy   User?     @relation("AnswerCommentDeletedBy", fields: [deletedById], references: [id])
}

model welcomeEmailJob {
  id          String @id
  jobId       String @unique
  createdAt   DateTime  @default(now())
}

enum UserRole {
  ADMIN
  USER
}
